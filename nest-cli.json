{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/core-api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/core-api/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/core-api",
  "projects": {
    "core-api": {
      "type": "application",
      "root": "apps/core-api",
      "entryFile": "main",
      "sourceRoot": "apps/core-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/core-api/tsconfig.app.json"
      }
    },
    "aura-api": {
      "type": "application",
      "root": "apps/aura-api",
      "entryFile": "main",
      "sourceRoot": "apps/aura-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/aura-api/tsconfig.app.json"
      }
    },
    "ems-api": {
      "type": "application",
      "root": "apps/ems-api",
      "entryFile": "main",
      "sourceRoot": "apps/ems-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ems-api/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    }
  }
}
